{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: run",
      "type": "shell",
      "command": "./dev.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": ["$javac"]
    },
    {
      "label": "dev: watch",
      "type": "shell",
      "command": "./watch.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "maven: package",
      "type": "shell",
      "command": "mvn -q package -Pdefault",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": ["$javac"]
    }
  ]
}
